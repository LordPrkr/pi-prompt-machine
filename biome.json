{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "ignoreUnknown": false, "includes": ["**", "!.repos", "!.local", "!.pi-subagents"] },
  "formatter": { "enabled": true, "lineWidth": 120, "indentStyle": "space", "indentWidth": 2 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noShadowRestrictedNames": "off" },
      "style": { "useBlockStatements": "error" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "single", "semicolons": "always", "trailingCommas": "all" } },
  "assist": { "enabled": true, "actions": { "source": { "organizeImports": "on" } } }
}
