{
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93",
    "happy-dom": "20.10.6",
    "mermaid": "11.16.0"
  },
  "devDependencies": {
    "@effect/tsgo": "0.19.0",
    "@effect/vitest": "4.0.0-beta.93",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "3.2.6",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "ultracite": "7.9.3",
    "vitest": "~3.2.6"
  },
  "name": "pi-prompt-machine",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "scripts": {
    "prepare": "lefthook install",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:unit": "vitest run --config vitest.config.unit.mts",
    "test:unit:watch": "vitest --config vitest.config.unit.mts",
    "test:integration": "vitest run --config vitest.config.integration.mts",
    "test:integration:watch": "vitest --config vitest.config.integration.mts",
    "test:coverage": "vitest run --config vitest.config.mts --coverage",
    "format": "oxfmt --disable-nested-config .",
    "lint": "oxlint --disable-nested-config .",
    "lint:fix": "oxlint --disable-nested-config --fix .",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "type": "module",
  "version": "0.3.1",
  "description": "Progressive-disclosure Mermaid workflows for Pi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LordPrkr/pi-prompt-machine.git"
  },
  "homepage": "https://github.com/LordPrkr/pi-prompt-machine#readme",
  "bugs": {
    "url": "https://github.com/LordPrkr/pi-prompt-machine/issues"
  },
  "packageManager": "bun@1.3.8",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "extensions",
    "skills",
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  }
}
